# Server Configuration
PORT=3001
JWT_SECRET=homebase_secret_key_7860

# Client Configuration
CLIENT_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3001

# One-click updates from the System page.
# The server container mounts the repo at this path.
HOMEBASE_UPDATE_CWD=/workspace/homebase
HOMEBASE_UPDATE_COMMAND=git pull --ff-only && docker compose up --build -d

# NAS management defaults
NAS_SMB_CONF=/etc/samba/smb.conf
NAS_EXPORTS_FILE=/etc/exports
NAS_HELPER=/usr/local/sbin/homebase-nas-helper
NAS_AGENT_URL=http://host.docker.internal:3015
NAS_AGENT_TOKEN=

#!/usr/bin/env bash
set -euo pipefail

SMB_CONF="/etc/samba/smb.conf"
EXPORTS_FILE="/etc/exports"

die() {
  echo "$*" >&2
  exit 1
}

need_arg() {
  [ "${1:-}" != "" ] || die "missing argument"
}

valid_service() {
  case "$1" in
    smbd|nmbd|nfs-kernel-server) return 0 ;;
    *) return 1 ;;
  esac
}

valid_service_action() {
  case "$1" in
    start|stop|restart|reload) return 0 ;;
    *) return 1 ;;
  esac
}

valid_path() {
  case "$1" in
    /*) return 0 ;;
    *) return 1 ;;
  esac
}

safe_mountpoint() {
  case "$1" in
    /mnt|/mnt/*|/media|/media/*|/run/media|/run/media/*|/Xube|/Xube/*) return 0 ;;
    *) return 1 ;;
  esac
}

backup_file() {
  local file="$1"
  local stamp
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  cp -a "$file" "${file}.homebase.${stamp}.bak"
}

write_smb_conf() {
  local tmp
  tmp="$(mktemp /tmp/homebase-smb.XXXXXX)"
  trap 'rm -f "$tmp"' RETURN
  cat > "$tmp"
  testparm -s "$tmp" >/dev/null
  backup_file "$SMB_CONF"
  install -o root -g root -m 0644 "$tmp" "$SMB_CONF"
  smbcontrol smbd reload-config >/dev/null 2>&1 || systemctl restart smbd
}

write_exports() {
  local tmp backup
  tmp="$(mktemp /tmp/homebase-exports.XXXXXX)"
  backup="$(mktemp /tmp/homebase-exports-backup.XXXXXX)"
  trap 'rm -f "$tmp" "$backup"' RETURN
  cat > "$tmp"
  touch "$EXPORTS_FILE"
  cp -a "$EXPORTS_FILE" "$backup"
  backup_file "$EXPORTS_FILE"
  install -o root -g root -m 0644 "$tmp" "$EXPORTS_FILE"
  if ! exportfs -ra; then
    install -o root -g root -m 0644 "$backup" "$EXPORTS_FILE"
    exportfs -ra || true
    die "exportfs -ra failed; restored previous exports file"
  fi
}

service_action() {
  local service="${1:-}"
  local action="${2:-}"
  need_arg "$service"
  need_arg "$action"
  valid_service "$service" || die "service not allowed"
  valid_service_action "$action" || die "service action not allowed"
  if [ "$action" = "reload" ] && [ "$service" = "nfs-kernel-server" ]; then
    exportfs -ra
    return
  fi
  systemctl "$action" "$service"
}

disconnect_samba_pid() {
  local pid="${1:-}"
  need_arg "$pid"
  [[ "$pid" =~ ^[0-9]+$ ]] || die "invalid pid"
  [ -d "/proc/$pid" ] || die "pid not found"
  if ! tr '\0' ' ' < "/proc/$pid/cmdline" | grep -Eq '(^|/| )smbd( |$)'; then
    die "pid is not an smbd process"
  fi
  kill -TERM "$pid"
}

mount_device() {
  local device="${1:-}"
  local mountpoint="${2:-}"
  local fstype="${3:-auto}"
  local options="${4:-defaults}"
  need_arg "$device"
  need_arg "$mountpoint"
  [[ "$device" =~ ^/dev/[A-Za-z0-9_.\/-]+$ ]] || die "invalid device"
  valid_path "$mountpoint" || die "invalid mountpoint"
  safe_mountpoint "$mountpoint" || die "mountpoint outside safe roots"
  [[ "$fstype" =~ ^[A-Za-z0-9_.-]+$ ]] || die "invalid fstype"
  [[ "$options" =~ ^[A-Za-z0-9_=,.-]+$ ]] || die "invalid options"
  mkdir -p "$mountpoint"
  mount -t "$fstype" -o "$options" "$device" "$mountpoint"
}

unmount_target() {
  local target="${1:-}"
  need_arg "$target"
  valid_path "$target" || die "invalid target"
  safe_mountpoint "$target" || die "target outside safe roots"
  umount "$target"
}

case "${1:-}" in
  health)
    echo "homebase-nas-helper ok"
    ;;
  write-smb-conf)
    write_smb_conf
    ;;
  write-exports)
    write_exports
    ;;
  reload-samba)
    smbcontrol smbd reload-config >/dev/null 2>&1 || systemctl restart smbd
    ;;
  reload-nfs)
    exportfs -ra
    ;;
  service-action)
    shift
    service_action "$@"
    ;;
  smbpasswd-add)
    shift
    need_arg "${1:-}"
    smbpasswd -s -a "$1"
    ;;
  smbpasswd-change)
    shift
    need_arg "${1:-}"
    smbpasswd -s "$1"
    ;;
  smbpasswd-delete)
    shift
    need_arg "${1:-}"
    smbpasswd -x "$1"
    ;;
  disconnect-samba-pid)
    shift
    disconnect_samba_pid "$@"
    ;;
  mount)
    shift
    mount_device "$@"
    ;;
  unmount)
    shift
    unmount_target "$@"
    ;;
  *)
    die "unknown action: ${1:-}"
    ;;
esac
